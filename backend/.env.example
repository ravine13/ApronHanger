# Database (Neon PostgreSQL)
# DATABASE_URL: Neon POOLED connection string (Neon dashboard → Connection pooling)
# DATABASE_URL="postgresql://user:pass@pooler.neon.tech/dbname?sslmode=require"

# DATABASE_URL_UNPOOLED: Neon DIRECT connection string (Neon dashboard → Direct connection)
# DATABASE_URL_UNPOOLED="postgresql://user:pass@direct.neon.tech/dbname?sslmode=require"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apronhanger"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/apronhanger"

# Server
NODE_ENV=production
PORT=3000

# Auth
JWT_SECRET="replace-with-a-strong-random-string-min-32-chars"

# CORS
# Set exact deployed frontend origins. Do not leave empty in production.
# ALLOWED_ORIGINS_CANDIDATE="https://candidate.example.com"
# ALLOWED_ORIGINS_RECRUITER="https://recruiter.example.com"
# ALLOWED_ORIGINS_ADMIN="https://admin.example.com"

# ALLOWED_ORIGINS_CANDIDATE=http://localhost:8082
# ALLOWED_ORIGINS_RECRUITER=http://localhost:8082
# ALLOWED_ORIGINS_ADMIN=http://localhost:8082

ALLOWED_ORIGINS_CANDIDATE=http://localhost:8082
ALLOWED_ORIGINS_RECRUITER=http://localhost:8081
ALLOWED_ORIGINS_ADMIN=http://localhost:8080

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Razorpay
# Test credentials are allowed here while validating the flow.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_test_secret"

# Admin seed
ADMIN_NAME="ApronHanger Admin"
ADMIN_EMAIL="admin@apronhanger.in"
ADMIN_PASSWORD="change-me-before-running-seed"

# Brevo transactional email
BREVO_API_KEY="your_brevo_api_key"
BREVO_SENDER_EMAIL="noreply@apronhanger.in"
BREVO_SENDER_NAME="ApronHanger Onboarding Team"
CANDIDATE_PORTAL_URL="https://candidate.example.com/applications"

# Fast2SMS OTP
FAST2SMS_API_KEY="your_fast2sms_api_key"
FAST2SMS_VERIFICATION_TEMPLATE_ID="your_verification_template_id"
FAST2SMS_RESET_TEMPLATE_ID="your_reset_template_id"

# Error monitoring (optional — app runs fine without this)
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

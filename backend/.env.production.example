# Production deployment template for Render (backend).
# Copy values into Render environment variables — do not commit real secrets.

# Database (Neon PostgreSQL)
# DATABASE_URL must be the Neon POOLED connection string (Connection pooling tab).
DATABASE_URL="postgresql://user:pass@pooler.neon.tech/dbname?sslmode=require"
# DATABASE_URL_UNPOOLED: Neon DIRECT connection — used by Prisma migrations only.
DATABASE_URL_UNPOOLED="postgresql://user:pass@direct.neon.tech/dbname?sslmode=require"

# Server
NODE_ENV=production
PORT=3000

# Auth — required; server refuses to start without this.
JWT_SECRET="replace-with-a-strong-random-string-min-32-chars"

# CORS — REQUIRED in production. Browser requests fail if these are empty.
# Use exact deployed frontend origins (no trailing slash).
ALLOWED_ORIGINS_CANDIDATE="https://jobs.example.com"
ALLOWED_ORIGINS_RECRUITER="https://recruiter.example.com"
ALLOWED_ORIGINS_ADMIN="https://admin.example.com"
# Optional legacy fallback (comma-separated):
# ALLOWED_ORIGINS="https://jobs.example.com,https://recruiter.example.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Razorpay
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_live_secret"
# Webhook secret — must match the value set in Razorpay Dashboard > Webhooks > Secret
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_min_32_chars"

# Admin seed (run once via `npm run seed:admin` after deploy)
ADMIN_NAME="ApronHanger Admin"
ADMIN_EMAIL="admin@apronhanger.in"
ADMIN_PASSWORD="change-me-before-running-seed"

# Brevo transactional email
BREVO_API_KEY="your_brevo_api_key"
BREVO_SENDER_EMAIL="noreply@apronhanger.in"
BREVO_SENDER_NAME="ApronHanger Onboarding Team"
CANDIDATE_PORTAL_URL="https://jobs.example.com/applications"

# Fast2SMS OTP
FAST2SMS_API_KEY="your_fast2sms_api_key"
FAST2SMS_VERIFICATION_TEMPLATE_ID="your_verification_template_id"
FAST2SMS_RESET_TEMPLATE_ID="your_reset_template_id"

# Error monitoring (optional — app runs fine without this; required for production alerting)
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
